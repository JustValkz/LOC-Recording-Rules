$script:KeywordUrl = 'https://raw.githubusercontent.com/reggiecarterthesecond-web/Recording-Policies/refs/heads/main/Tools/Keywords'

function Get-KeywordList {
    try { [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 } catch {}

    try {
        $response = Invoke-WebRequest -Uri $script:KeywordUrl -UseBasicParsing -TimeoutSec 8 -Headers @{ 'User-Agent' = 'Mozilla/5.0' }
        $text = [string]$response.Content
        $matches = [regex]::Matches($text, "['""]([^'""]+)['""]")
        $list = New-Object System.Collections.Generic.List[string]
        foreach ($match in $matches) {
            $word = $match.Groups[1].Value.Trim()
            if ($word -and -not $list.Contains($word)) { [void]$list.Add($word) }
        }
        return @($list)
    } catch {
        return @()
    }
}

$script:Keywords = @(Get-KeywordList)

function New-UIFont {
    param([float]$Size,[switch]$Bold)
    $style = [System.Drawing.FontStyle]::Regular
    if ($Bold) { $style = [System.Drawing.FontStyle]::Bold }
    return New-Object System.Drawing.Font -ArgumentList 'Segoe UI', $Size, $style
}

function Enable-DoubleBuffer {
    param([System.Windows.Forms.Control]$Control)
    try {
        $prop = $Control.GetType().GetProperty('DoubleBuffered', [System.Reflection.BindingFlags]'Instance, NonPublic')
        if ($prop) { $prop.SetValue($Control, $true, $null) }
    } catch {}
}

function Get-FormSize {
    try {
        $area = [System.Windows.Forms.Screen]::PrimaryScreen.WorkingArea
        $w = [Math]::Max(980, [int]($area.Width * 0.94))
        $h = [Math]::Max(620, [int]($area.Height * 0.90))
        return New-Object System.Drawing.Size($w, $h)
    } catch {
        return New-Object System.Drawing.Size(1250, 760)
    }
}

function Format-RelativeTime {
    param([datetime]$Time)
    $span = (Get-Date) - $Time
    if ($span.TotalSeconds -lt 10) { return 'Just now' }
    if ($span.TotalSeconds -lt 60) { return "$([int]$span.TotalSeconds) seconds ago" }
    if ($span.TotalMinutes -lt 60) {
        $m = [int]$span.TotalMinutes
        if ($m -eq 1) { return '1 minute ago' }
        return "$m minutes ago"
    }
    if ($span.TotalHours -lt 24) {
        $h = [int]$span.TotalHours
        if ($h -eq 1) { return '1 hour ago' }
        return "$h hours ago"
    }
    $d = [int]$span.TotalDays
    if ($d -eq 1) { return '1 day ago' }
    return "$d days ago"
}

function Wrap-LongText {
    param([string]$Text,[int]$Limit = 52)
    if ([string]::IsNullOrWhiteSpace($Text)) { return '' }
    $text = [string]$Text
    if ($text.Length -le $Limit) { return $text }
    $chunks = New-Object System.Collections.Generic.List[string]
    $start = 0
    while ($start -lt $text.Length) {
        $remaining = $text.Length - $start
        $take = [Math]::Min($Limit, $remaining)
        $chunk = $text.Substring($start, $take)
        if (($remaining -gt $Limit) -and ($chunk.LastIndexOf('\') -gt 8)) {
            $cut = $chunk.LastIndexOf('\') + 1
            $chunks.Add($text.Substring($start, $cut))
            $start += $cut
        } else {
            $chunks.Add($chunk)
            $start += $take
        }
    }
    return ($chunks -join "`r`n")
}

function Test-KeywordHit {
    param([string]$Text)
    foreach ($keyword in $script:Keywords) {
        try {
            if ($Text -match "(?i)$keyword") { return $keyword }
        } catch {}
    }
    return ''
}

function Get-PrefetchAppName {
    param([string]$FileName)
    $base = [System.IO.Path]::GetFileNameWithoutExtension($FileName)
    if ($base -match '^(.*)-[A-Fa-f0-9]{8}$') { return $matches[1] }
    return $base
}

function New-Table {
    $table = New-Object System.Data.DataTable
    foreach ($name in @('RelativeTime','LastRun','Application','FileName','SizeKB','KeywordHit')) {
        [void]$table.Columns.Add($name)
    }
    return ,$table
}

function Add-TableRow {
    param([System.Data.DataTable]$Table,[object]$Entry)
    $row = $Table.NewRow()
    $row['RelativeTime'] = $Entry.RelativeTime
    $row['LastRun'] = $Entry.LastRun
    $row['Application'] = $Entry.Application
    $row['FileName'] = $Entry.FileName
    $row['SizeKB'] = $Entry.SizeKB
    $row['KeywordHit'] = $Entry.KeywordHit
    [void]$Table.Rows.Add($row)
}

function Get-PrefetchRows {
    $rows = New-Object System.Collections.Generic.List[object]
    if (-not (Test-Path -LiteralPath $script:PrefetchPath)) { return $rows }
    $files = @(Get-ChildItem -LiteralPath $script:PrefetchPath -Filter '*.pf' -File -ErrorAction SilentlyContinue)
    foreach ($file in $files) {
        $app = Get-PrefetchAppName $file.Name
        $hit = Test-KeywordHit "$app $($file.Name)"
        $rows.Add([PSCustomObject]@{
            SortGroup = $(if ($hit) { 0 } else { 1 })
            Tick = $file.LastWriteTimeUtc.Ticks
            RelativeTime = Format-RelativeTime $file.LastWriteTime
            LastRun = $file.LastWriteTime.ToString('yyyy-MM-dd HH:mm:ss')
            Application = Wrap-LongText $app 52
            FileName = Wrap-LongText $file.Name 52
            SizeKB = [string][Math]::Round($file.Length / 1KB, 1)
            KeywordHit = $hit
        })
    }
    return @($rows | Sort-Object SortGroup, @{Expression='Tick';Descending=$true}, Application)
}

function Build-PrefetchTable {
    $table = New-Table
    foreach ($entry in (Get-PrefetchRows)) { Add-TableRow $table $entry }
    return ,$table
}

$table = Build-PrefetchTable

