$grid.AllowUserToDeleteRows = $false
$grid.AllowUserToResizeColumns = $true
$grid.AllowUserToResizeRows = $false
$grid.RowHeadersVisible = $false
$grid.MultiSelect = $false
$grid.SelectionMode = 'FullRowSelect'
$grid.BackgroundColor = [System.Drawing.Color]::FromArgb(24,24,24)
$grid.BorderStyle = 'None'
$grid.GridColor = [System.Drawing.Color]::FromArgb(55,55,55)
$grid.EnableHeadersVisualStyles = $false
$grid.ColumnHeadersBorderStyle = 'Single'
$grid.ColumnHeadersDefaultCellStyle.BackColor = [System.Drawing.Color]::FromArgb(34,34,34)
$grid.ColumnHeadersDefaultCellStyle.ForeColor = [System.Drawing.Color]::Gainsboro
$grid.ColumnHeadersDefaultCellStyle.Font = New-UIFont 9 -Bold
$grid.ColumnHeadersDefaultCellStyle.WrapMode = [System.Windows.Forms.DataGridViewTriState]::True
$grid.ColumnHeadersHeightSizeMode = 'AutoSize'
$grid.DefaultCellStyle.BackColor = [System.Drawing.Color]::FromArgb(30,30,30)
$grid.DefaultCellStyle.ForeColor = [System.Drawing.Color]::Gainsboro
$grid.DefaultCellStyle.SelectionBackColor = [System.Drawing.Color]::FromArgb(70,70,70)
$grid.DefaultCellStyle.SelectionForeColor = [System.Drawing.Color]::White
$grid.DefaultCellStyle.Font = New-UIFont 9
$grid.DefaultCellStyle.WrapMode = [System.Windows.Forms.DataGridViewTriState]::True
