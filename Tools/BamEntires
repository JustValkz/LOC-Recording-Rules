function Format-RelativeTime {
    param([datetime]$Time)
    $span = (Get-Date) - $Time
    if ($span.TotalSeconds -lt 10) { return 'Just now' }
    if ($span.TotalSeconds -lt 60) { return "$([int]$span.TotalSeconds) seconds ago" }
    if ($span.TotalMinutes -lt 60) {
        $m = [int]$span.TotalMinutes
        if ($m -eq 1) { return '1 minute ago' }
        return "$m minutes ago"
    }
    if ($span.TotalHours -lt 24) {
        $h = [int]$span.TotalHours
        if ($h -eq 1) { return '1 hour ago' }
        return "$h hours ago"
    }
    $d = [int]$span.TotalDays
    if ($d -eq 1) { return '1 day ago' }
    return "$d days ago"
}

function Wrap-LongText {
    param([string]$Text,[int]$Limit = 54)
    if ([string]::IsNullOrWhiteSpace($Text)) { return '' }
    $text = [string]$Text
    if ($text.Length -le $Limit) { return $text }

    if ($text -like '*\*') {
        $lines = New-Object System.Collections.Generic.List[string]
        $current = ''
        $parts = $text -split '\\'
        foreach ($part in $parts) {
            if ($current.Length -eq 0) {
                $next = $part
            } else {
                $next = "$current\$part"
            }
            if ($next.Length -gt $Limit -and $current.Length -gt 0) {
                [void]$lines.Add($current + '\')
                $current = $part
            } else {
                $current = $next
            }
        }
        if ($current.Length -gt 0) { [void]$lines.Add($current) }
        return ($lines -join "`r`n")
    }

    $chunks = New-Object System.Collections.Generic.List[string]
    $start = 0
    while ($start -lt $text.Length) {
        $take = [Math]::Min($Limit, $text.Length - $start)
        [void]$chunks.Add($text.Substring($start, $take))
        $start += $take
    }
    return ($chunks -join "`r`n")
}

function Test-KeywordHit {
    param([string]$Text)
    foreach ($keyword in $script:Keywords) {
        try {
            if ($Text -match "(?i)$keyword") { return $keyword }
        } catch {}
    }
    return ''
}

function Resolve-BamPath {
    param([string]$RawPath)
    if ([string]::IsNullOrWhiteSpace($RawPath)) { return '' }

    $path = [string]$RawPath
    if ($path.StartsWith('\??\')) { return $path.Substring(4) }
    if ($path -match '^[A-Za-z]:\\') { return $path }

    if ($path -match '^\\Device\\HarddiskVolume\d+\\(.+)$') {
        $tail = $matches[1]
        foreach ($drive in @(Get-PSDrive -PSProvider FileSystem -ErrorAction SilentlyContinue | Where-Object { $_.Root -match '^[A-Za-z]:\\$' })) {
            try {
                $candidate = Join-Path $drive.Root $tail
                if (Test-Path -LiteralPath $candidate) { return $candidate }
            } catch {}
        }
        if ($env:SystemDrive) { return (Join-Path ($env:SystemDrive + '\') $tail) }
    }

    return $path
}

function Get-SignatureState {
    param([string]$Path)
    if ([string]::IsNullOrWhiteSpace($Path)) { return 'N/A' }
    if ($script:SignatureCache.ContainsKey($Path)) { return $script:SignatureCache[$Path] }

    $state = 'N/A'
    try {
        if (Test-Path -LiteralPath $Path) {
            $sig = Get-AuthenticodeSignature -LiteralPath $Path
            if ($sig.Status -eq 'Valid') {
                $state = 'Valid'
            } elseif ($sig.Status -eq 'NotSigned' -or $sig.Status -eq 'UnknownError') {
                $state = 'N/A'
            } else {
                $state = 'Invalid'
            }
        }
    } catch {
        $state = 'N/A'
    }

    $script:SignatureCache[$Path] = $state
    return $state
}

function Get-SortGroup {
    param([string]$KeywordHit,[string]$Signature)
    if ($KeywordHit) { return 0 }
    if ($Signature -eq 'Invalid') { return 1 }
    if ($Signature -eq 'N/A') { return 2 }
    if ($Signature -eq 'Valid') { return 3 }
    return 4
}

function New-Table {
    $table = New-Object System.Data.DataTable
    foreach ($name in @('RelativeTime','LastRun','Application','Path','Signature','KeywordHit','UserSID')) {
        [void]$table.Columns.Add($name)
    }
    return ,$table
}

function Add-TableRow {
    param([System.Data.DataTable]$Table,[object]$Entry)
    $row = $Table.NewRow()
    $row['RelativeTime'] = $Entry.RelativeTime
    $row['LastRun'] = $Entry.LastRun
    $row['Application'] = $Entry.Application
    $row['Path'] = $Entry.Path
    $row['Signature'] = $Entry.Signature
    $row['KeywordHit'] = $Entry.KeywordHit
    $row['UserSID'] = $Entry.UserSID
    [void]$Table.Rows.Add($row)
}

function Get-BamRows {
    $rows = New-Object System.Collections.Generic.List[object]
    if (-not (Test-Path -LiteralPath $script:BamRoot)) { return $rows }

    $sidKeys = @(Get-ChildItem -LiteralPath $script:BamRoot -ErrorAction SilentlyContinue)
    foreach ($sidKey in $sidKeys) {
        $sid = $sidKey.PSChildName
        $keyPath = Join-Path $script:BamRoot $sid
        $props = Get-ItemProperty -LiteralPath $keyPath -ErrorAction SilentlyContinue
        if (-not $props) { continue }

        foreach ($prop in $props.PSObject.Properties) {
            if ($prop.Name -like 'PS*' -or $prop.Name -eq '(default)') { continue }
            $raw = $prop.Value
            if (-not $raw -or $raw.Length -lt 8) { continue }

            try {
                $fileTime = [BitConverter]::ToInt64($raw[0..7], 0)
                if ($fileTime -le 0) { continue }

                $time = [DateTime]::FromFileTimeUtc($fileTime).ToLocalTime()
                $path = Resolve-BamPath $prop.Name
                $app = Split-Path $path -Leaf
                if ([string]::IsNullOrWhiteSpace($app)) { $app = Split-Path $prop.Name -Leaf }
                if ([string]::IsNullOrWhiteSpace($app)) { $app = $prop.Name }

                $hit = Test-KeywordHit "$app $path $($prop.Name)"
                $sig = Get-SignatureState $path

                $rows.Add([PSCustomObject]@{
                    SortGroup = Get-SortGroup $hit $sig
                    Tick = $fileTime
                    RelativeTime = Format-RelativeTime $time
                    LastRun = $time.ToString('yyyy-MM-dd HH:mm:ss')
                    Application = Wrap-LongText $app 42
                    Path = Wrap-LongText $path 58
                    Signature = $sig
                    KeywordHit = $hit
                    UserSID = Wrap-LongText $sid 38
                })
            } catch {}
        }
    }

    return @($rows | Sort-Object SortGroup, @{Expression='Tick';Descending=$true}, Application)
}

function Build-BamTable {
    $table = New-Table
    foreach ($entry in (Get-BamRows)) { Add-TableRow $table $entry }
    return ,$table
}

