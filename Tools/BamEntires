$grid.Add_DataBindingComplete({
    param($sender,$e)
    foreach ($col in $sender.Columns) {
        $col.SortMode = 'NotSortable'
        $col.DefaultCellStyle.WrapMode = [System.Windows.Forms.DataGridViewTriState]::True
        switch ($col.Name) {
            'RelativeTime' { $col.FillWeight = 13; $col.MinimumWidth = 120 }
            'LastRun'      { $col.FillWeight = 17; $col.MinimumWidth = 150 }
            'Application'  { $col.FillWeight = 20; $col.MinimumWidth = 170 }
            'Path'         { $col.FillWeight = 45; $col.MinimumWidth = 310 }
            'Signature'    { $col.FillWeight = 12; $col.MinimumWidth = 100 }
            'KeywordHit'   { $col.FillWeight = 12; $col.MinimumWidth = 110 }
            'UserSID'      { $col.FillWeight = 18; $col.MinimumWidth = 160 }
        }
    }

    foreach ($row in $sender.Rows) {
        $hit = ''
        $sig = ''
        try { $hit = [string]$row.Cells['KeywordHit'].Value } catch {}
        try { $sig = [string]$row.Cells['Signature'].Value } catch {}

        if ($hit -or $sig -eq 'Invalid') {
            $row.DefaultCellStyle.BackColor = [System.Drawing.Color]::FromArgb(84,36,64)
            $row.DefaultCellStyle.ForeColor = [System.Drawing.Color]::White
        } elseif ($sig -eq 'N/A') {
            $row.DefaultCellStyle.BackColor = [System.Drawing.Color]::FromArgb(70,62,28)
            $row.DefaultCellStyle.ForeColor = [System.Drawing.Color]::White
        } elseif ($sig -eq 'Valid') {
            $row.DefaultCellStyle.BackColor = [System.Drawing.Color]::FromArgb(28,64,42)
            $row.DefaultCellStyle.ForeColor = [System.Drawing.Color]::White
        } else {
            $row.Cells['RelativeTime'].Style.BackColor = [System.Drawing.Color]::FromArgb(92,58,24)
            $row.Cells['RelativeTime'].Style.ForeColor = [System.Drawing.Color]::White
        }
    }
})

$scrollTimer = New-Object System.Windows.Forms.Timer
$scrollTimer.Interval = 120
$scrollTimer.Add_Tick({
    if (-not $autoScrollCheck.Checked) { return }
    if ($grid.RowCount -le 0) { return }
    try {
        $visibleCount = $grid.DisplayedRowCount($false)
        if ($visibleCount -lt 1) { $visibleCount = 1 }
        $maxFirst = [Math]::Max(0, $grid.RowCount - $visibleCount)
        $step = 1
        if ($speedBox.SelectedItem -eq 'Fast') { $step = 3 }
        elseif ($speedBox.SelectedItem -eq 'Slow') { $step = 1 }
        else { $step = 2 }
        $next = $grid.FirstDisplayedScrollingRowIndex + $step
        if ($next -gt $maxFirst) {
            $autoScrollCheck.Checked = $false
            return
        }
        $grid.FirstDisplayedScrollingRowIndex = $next
    } catch {}
})

$autoScrollCheck.Add_CheckedChanged({
    if ($autoScrollCheck.Checked) { $scrollTimer.Start() } else { $scrollTimer.Stop() }
})

$speedBox.Add_SelectedIndexChanged({
    if ($speedBox.SelectedItem -eq 'Fast') { $scrollTimer.Interval = 75 }
    elseif ($speedBox.SelectedItem -eq 'Slow') { $scrollTimer.Interval = 180 }
    else { $scrollTimer.Interval = 120 }
})

$form.Add_FormClosing({
    try { $scrollTimer.Stop() } catch {}
})

