            $exePath = $proc.ExecutablePath
            if (-not $exePath) { continue }
            $norm = Get-NormalizedPath $exePath
            if (Test-StartsWithAnyPath -Path $norm -Prefixes $monitoredExePaths) { [void]$prevRunningPathProcesses.Add("$($proc.ProcessId)|$norm") }
        }
    } catch {}

