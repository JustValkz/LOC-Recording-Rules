        'https://download.sysinternals.com/files/processexplorer.zip',
        'https://raw.githubusercontent.com/reggiecarterthesecond-web/recording-policies/refs/heads/main/tools/bamentires',
        'https://raw.githubusercontent.com/reggiecarterthesecond-web/recording-policies/refs/heads/main/tools/prefetch',
        'https://raw.githubusercontent.com/reggiecarterthesecond-web/recording-policies/refs/heads/main/tools/keywords'
    )

    $dnsTargets = @(
        @{ Label = 'GitHub'; Patterns = @('(^|\.)github\.com$', '(^|\.)raw\.githubusercontent\.com$', '(^|\.)gitlab\.com$', '(^|\.)bitbucket\.org$', '(^|\.)jsdelivr\.net$') },
        @{ Label = 'KeyAuth'; Patterns = @('(^|\.)keyauth\.[a-z]+$') },
        @{ Label = 'Pastebin / code-paste site'; Patterns = @(
            '(^|\.)pastebin\.com$',
            '(^|\.)ghostbin\.[a-z]+$',
            '(^|\.)hastebin\.[a-z]+$',
            '(^|\.)paste\.ee$',
            '(^|\.)paste\.gg$',
            '(^|\.)justpaste\.it$',
            '(^|\.)dpaste\.[a-z]+$',
            '(^|\.)controlc\.com$',
            '(^|\.)pastecode\.[a-z]+$',
            '(^|\.)rentry\.co$',
            '(^|\.)textbin\.[a-z]+$',
            '(^|\.)0bin\.[a-z]+$',
            '(^|\.)privatebin\.[a-z]+$'
        ) }
    )

    $alertedDnsLabels = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)
    $jobPID = $PID
    $procQueue = [System.Collections.Concurrent.ConcurrentQueue[string]]::new()
    $normalizedScriptPath = Get-NormalizedPath $scriptPath

    Register-ProcessWatcher -NormalizedScriptPath $normalizedScriptPath -MainPID $currentPID -WorkerPID $jobPID -Queue $procQueue -MonitoredPaths $monitoredExePaths -AllowedCommandMarkers $allowedCommandMarkers
    Update-Heartbeat -Path $heartbeatPath

    while ($true) {
        Update-Heartbeat -Path $heartbeatPath

        if (-not (Get-EventSubscriber -SourceIdentifier ProcessStartEvent -ErrorAction SilentlyContinue)) {
            Write-LiveEvent 'Monitor integrity warning: process watcher was missing and was recreated.'
            Register-ProcessWatcher -NormalizedScriptPath $normalizedScriptPath -MainPID $currentPID -WorkerPID $jobPID -Queue $procQueue -MonitoredPaths $monitoredExePaths -AllowedCommandMarkers $allowedCommandMarkers
        }

        $curUSB = Get-USBDrives
        $usbAdded = $curUSB | Where-Object { $_ -notin $prevUSB }
        $usbRemoved = $prevUSB | Where-Object { $_ -notin $curUSB }

