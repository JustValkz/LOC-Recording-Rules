function Format-RelativeTime {
    param([datetime]$Time)
    $span = (Get-Date) - $Time
    if ($span.TotalSeconds -lt 10) { return 'Just now' }
    if ($span.TotalSeconds -lt 60) { return "$([int]$span.TotalSeconds) seconds ago" }
    if ($span.TotalMinutes -lt 60) {
        $m = [int]$span.TotalMinutes
        if ($m -eq 1) { return '1 minute ago' }
        return "$m minutes ago"
    }
    if ($span.TotalHours -lt 24) {
        $h = [int]$span.TotalHours
        if ($h -eq 1) { return '1 hour ago' }
        return "$h hours ago"
    }
    $d = [int]$span.TotalDays
    if ($d -eq 1) { return '1 day ago' }
    return "$d days ago"
}

function Wrap-LongText {
    param([string]$Text,[int]$Limit = 52)
    if ([string]::IsNullOrWhiteSpace($Text)) { return '' }
    $text = [string]$Text
    if ($text.Length -le $Limit) { return $text }

    $chunks = New-Object System.Collections.Generic.List[string]
    $start = 0
    while ($start -lt $text.Length) {
        $remaining = $text.Length - $start
        $take = [Math]::Min($Limit, $remaining)
        $chunk = $text.Substring($start, $take)

        if (($remaining -gt $Limit) -and ($chunk.LastIndexOf('\') -gt 8)) {
            $cut = $chunk.LastIndexOf('\') + 1
            $chunks.Add($text.Substring($start, $cut))
            $start += $cut
        } else {
            $chunks.Add($chunk)
            $start += $take
        }
    }

    return ($chunks -join "`r`n")
}

