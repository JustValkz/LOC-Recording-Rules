$monitorIntegrityState = "Unknown"
$monitorIntegrityMessage = "Monitor integrity could not be verified."

$jobRef = Get-Job -Name 'LiveMonitor' -ErrorAction SilentlyContinue
$heartbeatFresh = $false

if ($jobRef) {
    if ($jobRef.State -eq 'Running') {
        if (Test-Path $monitorHeartbeatPath) {
            try {
                $heartbeatAge = ((Get-Date) - (Get-Item $monitorHeartbeatPath).LastWriteTime).TotalSeconds
                if ($heartbeatAge -le 5) {
                    $heartbeatFresh = $true
                }
            } catch {}
        }

        if ($heartbeatFresh) {
            $monitorIntegrityState = "OK"
            $monitorIntegrityMessage = "Monitor integrity: OK - live monitor heartbeat confirmed."
        } else {
            $monitorIntegrityState = "Warning"
            $monitorIntegrityMessage = "Monitor integrity warning: live monitor heartbeat was stale or missing."
        }
    } else {
        $monitorIntegrityState = "Warning"
        $monitorIntegrityMessage = "Monitor integrity warning: live monitor job was not running (State: $($jobRef.State))."
    }
} else {
    $monitorIntegrityState = "Warning"
    $monitorIntegrityMessage = "Monitor integrity warning: live monitor job was missing."
}

Add-Event -List $eventList -Message $monitorIntegrityMessage

Stop-Job -Name 'LiveMonitor' -ErrorAction SilentlyContinue
$liveEvents = Receive-Job -Name 'LiveMonitor' -ErrorAction SilentlyContinue
Remove-Job -Name 'LiveMonitor' -Force -ErrorAction SilentlyContinue

if (Test-Path $monitorHeartbeatPath) {
    Remove-Item $monitorHeartbeatPath -Force -ErrorAction SilentlyContinue
}

Clear-Host
Write-Host "[ Step 6 of 6 - Monitoring - Results ]" -ForegroundColor Cyan
Show-LoadingBar "Step 6"

Write-Host ""
Write-Host "=== Initial System Overview ===" -ForegroundColor Cyan

if ($monitorIntegrityState -eq 'OK') {
    Write-Host "Live monitor integrity: ACTIVE" -ForegroundColor Green
} else {
    Write-Host "Live monitor integrity: WARNING" -ForegroundColor Red
}

if ($initialUSB.Count -eq 0) {
    Write-Host "USB drives: None connected" -ForegroundColor Green
} else {
    Write-Host "USB drives connected: $($initialUSB -join ', ')" -ForegroundColor Yellow
}

if ($initialExclusions.Count -eq 0) {
    Write-Host "Defender exclusions: None" -ForegroundColor Green
} else {
    Write-Host "Defender exclusions active:" -ForegroundColor Red
    foreach ($ex in $initialExclusions) {
        Write-Host "  - $ex" -ForegroundColor Red
    }
}

if ($initialRTP -eq $true) {
    Write-Host "Real-time protection: ENABLED" -ForegroundColor Green
}
elseif ($initialRTP -eq $false) {
    Write-Host "Real-time protection: DISABLED" -ForegroundColor Red
}
else {
    Write-Host "Real-time protection: Unknown" -ForegroundColor Yellow
}

$registryIssues = $false
foreach ($base in $registryBasePaths) {
    if ($initialRegistry[$base].Count -gt 0) {
        $registryIssues = $true
    }
}

if (-not $registryIssues) {
    Write-Host "Defender registry paths: Clean" -ForegroundColor Green
} else {
    Write-Host "Defender registry paths: Issues found" -ForegroundColor Red
    foreach ($base in $registryBasePaths) {
        foreach ($key in $initialRegistry[$base].Keys) {
            Write-Host "  - $key : $($initialRegistry[$base][$key])" -ForegroundColor Red
        }
    }
}

$folderIssues = $false
foreach ($folderInfo in $initialFolders.Values) {
    if ($folderInfo.Path) {
        $folderIssues = $true
    }
}

if (-not $folderIssues) {
    Write-Host "Monitored folders: None found (clean)" -ForegroundColor Green
} else {
    Write-Host "Monitored folders: Found" -ForegroundColor Red
    foreach ($folderInfo in $initialFolders.Values) {
        if ($folderInfo.Path) {
            Write-Host "  - $($folderInfo.Path)" -ForegroundColor Red
            foreach ($item in $folderInfo.Contents) {
                Write-Host "      Content: $item" -ForegroundColor Yellow
            }
        }
    }
}

if (-not $initialThreats -or $initialThreats.Count -eq 0) {
    Write-Host "Defender threat history: None" -ForegroundColor Green
} else {
    Write-Host "Defender threat history:" -ForegroundColor Red
    foreach ($t in $initialThreats) {
        $status = switch ($t.ThreatStatus) {
            1 { "Allowed" }
            2 { "Quarantined" }
            3 { "Removed" }
            default { "Detected" }
        }

        $line = "  - $($t.ThreatName) | $status | $($t.DetectionTime)"
        if ($line -match '(?i)roblox') {
            Write-Host $line -ForegroundColor Yellow
        } else {
            Write-Host $line -ForegroundColor Red
        }
    }
}

Write-Host ""
Write-Host "=== Detection Logs ===" -ForegroundColor Cyan

$groupedLive = @()
$psCounter = 0
$firstTimestamp = $null
$pendingPS = $false

foreach ($line in $liveEvents) {
    if ($line -match '^\[(.*?)\] PowerShell (command executed|script executed \(\d+ lines\))') {
        $timestamp = $matches[1]
        if (-not $pendingPS) {
            $firstTimestamp = $timestamp
            $pendingPS = $true
            $psCounter = 1
        } else {
            $psCounter++
        }
    } else {
        if ($pendingPS) {
            $groupedLive += "[$firstTimestamp] PowerShell execution detected ($psCounter executions)"
            $pendingPS = $false
            $psCounter = 0
            $firstTimestamp = $null
        }

        $groupedLive += $line
    }
}

if ($pendingPS) {
    $groupedLive += "[$firstTimestamp] PowerShell execution detected ($psCounter executions)"
}

$allDetections = $eventList + $groupedLive

if ($allDetections.Count -eq 0) {
    Write-Host "No detections." -ForegroundColor Green
} else {
    foreach ($evt in $allDetections) {
        if ($evt -match '(?i)roblox') {
            Write-Host $evt -ForegroundColor Yellow
        }
        elseif ($evt -match "USB inserted|USB removed") {
            Write-Host $evt -ForegroundColor Yellow
        }
        elseif ($evt -match "Exclusion added|Exclusion removed|Real-time protection changed|Registry key|Folder CREATED|Folder DELETED|New item created|Defender threat|Defender action|Defender malware|Defender severe|Defender event|PowerShell history file was CLEARED|PowerShell history file was TRUNCATED|DNS match found|Process started|Suspicious EXE started|Running EXE detected in monitored path|Monitor integrity warning") {
            Write-Host $evt -ForegroundColor Red
        }
        elseif ($evt -match "PowerShell (command|script|execution)") {
            Write-Host $evt -ForegroundColor Magenta
        }
        elseif ($evt -match "Monitor integrity: OK") {
            Write-Host $evt -ForegroundColor Green
        }
        else {
            Write-Host $evt -ForegroundColor White
        }
    }
}

if (Confirm-ExitWithDelay) {
    Stop-Process -Id $PID
}
