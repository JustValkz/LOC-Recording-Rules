function Test-DriveHasExe {
    param([string]$DriveRoot)

    if (-not $DriveRoot) { return $false }

    $root = if ($DriveRoot.EndsWith('\')) { $DriveRoot } else { "$DriveRoot\" }

    try {
        foreach ($file in [System.IO.Directory]::EnumerateFiles($root, '*.exe', [System.IO.SearchOption]::AllDirectories)) {
            return $true
        }
    } catch {
        try {
            $found = Get-ChildItem -Path $root -Filter '*.exe' -File -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1
            if ($found) { return $true }
        } catch {}
    }

    return $false
}

function Get-Exclusions {
    $list = @()

    try {
        $prefs = Get-MpPreference -ErrorAction Stop
        if ($prefs.ExclusionPath) { $list += $prefs.ExclusionPath }
        if ($prefs.ExclusionProcess) { $list += $prefs.ExclusionProcess }
        if ($prefs.ExclusionExtension) { $list += $prefs.ExclusionExtension }
    } catch {}

    $list
}

function Get-RegistryContentRecursive {
    param([string]$BasePath)

    $results = @{}
    if (-not (Test-Path $BasePath)) { return $results }

    try {
        foreach ($item in (Get-ChildItem -Path $BasePath -Recurse -ErrorAction SilentlyContinue)) {
            if ($item.PSChildName -eq '(default)') { continue }

            $props = Get-ItemProperty -Path $item.PSPath -ErrorAction SilentlyContinue
            if (-not $props) { continue }

            $nonDefault = $props.PSObject.Properties | Where-Object {
                $_.Name -notlike 'PS*' -and $_.Name -ne '(default)' -and $_.Value -ne $null -and $_.Value -ne ''
            }

            if ($nonDefault.Count -gt 0) {
                $results[$item.PSPath] = ($nonDefault | ForEach-Object { "$($_.Name)=$($_.Value)" }) -join ', '
            }
        }
    } catch {}

    $results
}

function Get-ExistingFolderPath {
    param(
        [string]$BaseDir,
        [string]$FolderName
    )

    try {
        $candidate = Join-Path $BaseDir $FolderName
        if (Test-Path $candidate -PathType Container) {
            return (Get-Item $candidate -ErrorAction SilentlyContinue).FullName
        }
    } catch {}

    $null
}

function Get-FolderContentsSet {
    param([string]$FolderPath)

    $set = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)

    if (-not $FolderPath) { return $set }
    if (-not (Test-Path $FolderPath -PathType Container)) { return $set }

    try {
        foreach ($child in (Get-ChildItem -Path $FolderPath -Force -ErrorAction Stop)) {
            [void]$set.Add($child.Name)
        }
    } catch {}

    $set
}

function Get-NormalizedPath {
    param([string]$Path)

    if (-not $Path) { return $null }

    try {
        return [System.IO.Path]::GetFullPath($Path).TrimEnd('\').ToLowerInvariant()
    } catch {
        return $Path.TrimEnd('\').ToLowerInvariant()
    }
}

function Test-StartsWithAnyPath {
    param(
        [string]$Path,
        [string[]]$Prefixes
    )

    if (-not $Path) { return $false }

    foreach ($prefix in $Prefixes) {
        if (-not $prefix) { continue }
        if ($Path -eq $prefix -or $Path.StartsWith($prefix + '\')) { return $true }
    }

    return $false
}

function Get-EmbeddedBamToolScript {
    return @'
# BAM REVIEW (lite)
$ErrorActionPreference = 'SilentlyContinue'
Add-Type -AssemblyName System.Windows.Forms
Add-Type -AssemblyName System.Drawing
[System.Windows.Forms.Application]::EnableVisualStyles()

$BamRoot = 'HKLM:\SYSTEM\CurrentControlSet\Services\bam\State\UserSettings'
$MaxRows = 120
$Cutoff = (Get-Date).AddDays(-3)

$Keywords = @(
'matcha','evolve','mooze','matrix','aimmy','aimbot','triggerbot','silentaim','valex','vector','photon','nezur',
'haze','myst','horizon','havoc','xeno','solara','fluxus','clumsy','dx9ware','mapper','bootstrapper','loader',
