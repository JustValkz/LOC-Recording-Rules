function Show-LoadingBar {
    param([string]$StepName)

    for ($i = 0; $i -le 20; $i++) {
        $percent = $i * 5
        $bar = ("#" * $i) + ("-" * (20 - $i))
        Write-Host "`r[ $bar ] $percent%" -NoNewline
        Start-Sleep -Milliseconds 120
    }

    Write-Host "`n"
}

function Wait-ForEnter {
    Start-Sleep -Milliseconds 250

    try {
        while ([Console]::KeyAvailable) {
            [Console]::ReadKey($true) | Out-Null
            Start-Sleep -Milliseconds 25
        }
    } catch {}

    [Console]::ReadLine() | Out-Null
}


function Initialize-WindowTools {
    try {
        if (-not ('WindowTools' -as [type])) {
            Add-Type -TypeDefinition @"
using System;
using System.Runtime.InteropServices;
public static class WindowTools {
    [DllImport("user32.dll")]
    public static extern bool ShowWindowAsync(IntPtr hWnd, int nCmdShow);
}
"@
        }
    } catch {}
}

function Show-ProcessWindowMaximized {
    param(
        [System.Diagnostics.Process]$Process,
        [int]$TimeoutSeconds = 8
    )

    if (-not $Process) { return }
    Initialize-WindowTools

    try { [void]$Process.WaitForInputIdle(3000) } catch {}

    $deadline = (Get-Date).AddSeconds($TimeoutSeconds)
    while ((Get-Date) -lt $deadline) {
        try {
            $p = Get-Process -Id $Process.Id -ErrorAction SilentlyContinue
            if ($p -and $p.MainWindowHandle -and $p.MainWindowHandle -ne [IntPtr]::Zero) {
                [void][WindowTools]::ShowWindowAsync($p.MainWindowHandle, 3)
                return
            }
        } catch {}

        Start-Sleep -Milliseconds 200
    }
}

function Start-MaximizedProcess {
    param(
        [string]$FilePath,
        [string[]]$ArgumentList = @()
    )

    $p = $null
    try {
        if ($ArgumentList -and $ArgumentList.Count -gt 0) {
            $p = Start-Process -FilePath $FilePath -ArgumentList $ArgumentList -WindowStyle Maximized -PassThru -ErrorAction Stop
        } else {
            $p = Start-Process -FilePath $FilePath -WindowStyle Maximized -PassThru -ErrorAction Stop
        }
    } catch {
        try {
            if ($ArgumentList -and $ArgumentList.Count -gt 0) {
                $p = Start-Process -FilePath $FilePath -ArgumentList $ArgumentList -PassThru -ErrorAction Stop
            } else {
                $p = Start-Process -FilePath $FilePath -PassThru -ErrorAction Stop
            }
        } catch {}
    }

    if ($p) { Show-ProcessWindowMaximized -Process $p }
    return $p
}

function Maximize-ResourceMonitorWindow {
    $deadline = (Get-Date).AddSeconds(8)
    while ((Get-Date) -lt $deadline) {
        try {
            $resourceProcesses = Get-Process -Name 'resmon','perfmon' -ErrorAction SilentlyContinue
            foreach ($resourceProcess in $resourceProcesses) {
                $title = ''
                try { $title = $resourceProcess.MainWindowTitle } catch {}
                if ($resourceProcess.ProcessName -ieq 'resmon' -or $title -match 'Resource Monitor') {
                    Show-ProcessWindowMaximized -Process $resourceProcess -TimeoutSeconds 2
                    return
                }
            }
        } catch {}
        Start-Sleep -Milliseconds 250
    }
}

function Close-ResourceMonitorWindow {
    try {
        $resourceProcesses = Get-Process -Name 'resmon','perfmon' -ErrorAction SilentlyContinue

        foreach ($resourceProcess in $resourceProcesses) {
            $title = ''
            try { $title = $resourceProcess.MainWindowTitle } catch {}

            if ($resourceProcess.ProcessName -ieq 'resmon' -or $title -match 'Resource Monitor') {
                try {
                    if (-not $resourceProcess.HasExited) {
                        [void]$resourceProcess.CloseMainWindow()
                        Start-Sleep -Milliseconds 700
                    }
                } catch {}

                try {
                    if (-not $resourceProcess.HasExited) {
                        Stop-Process -Id $resourceProcess.Id -Force -ErrorAction SilentlyContinue
                    }
                } catch {}
            }
        }
    } catch {}
}

function Confirm-ExitWithDelay {
    while ($true) {
        Write-Host ""
        Write-Host "Do you want to exit?" -ForegroundColor Yellow
        Write-Host "Press Enter after the countdown to exit, or type N then press Enter to stay on this screen." -ForegroundColor Yellow

        try {
            while ([Console]::KeyAvailable) {
                [Console]::ReadKey($true) | Out-Null
                Start-Sleep -Milliseconds 25
            }
        } catch {}

        for ($i = 3; $i -ge 1; $i--) {
            Write-Host "`rExit unlocks in $i second(s)...   " -ForegroundColor Cyan -NoNewline
            try { [Console]::Out.Flush() } catch {}
            Start-Sleep -Seconds 1
        }

        Write-Host "`rYou can press Enter now to exit, or type N then press Enter to stay.          " -ForegroundColor Yellow

        try {
            while ([Console]::KeyAvailable) {
                [Console]::ReadKey($true) | Out-Null
                Start-Sleep -Milliseconds 25
            }
        } catch {}

        $answer = [Console]::ReadLine()

        if ([string]::IsNullOrWhiteSpace($answer)) { return $true }
        if ($answer.Trim() -match '^(n|no)$') {
            Write-Host "Exit cancelled. Results will stay open." -ForegroundColor Green
            continue
        }
        if ($answer.Trim() -match '^(y|yes)$') { return $true }

        Write-Host "Invalid choice. Press Enter to exit, or type N to stay." -ForegroundColor Yellow
    }
}

function Write-Section {
    param($Title, $Lines)

    Write-Host "--- $Title ---" -ForegroundColor Cyan

    foreach ($line in $Lines) {
        if ($line -like "SUCCESS*") { Write-Host $line -ForegroundColor Green }
        elseif ($line -like "FAILURE*") { Write-Host $line -ForegroundColor Red }
        elseif ($line -like "WARNING*") { Write-Host $line -ForegroundColor Yellow }
        elseif ($line -like "INFO*") { Write-Host $line -ForegroundColor Yellow }
        else { Write-Host $line -ForegroundColor White }
    }

    Write-Host ""
}

