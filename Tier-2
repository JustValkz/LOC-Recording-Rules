$monitorJob = Start-Job -Name 'LiveMonitor' -ScriptBlock {
    param(
        $folderTargets,
        $registryBasePaths,
        $psHistoryPath,
        $scriptPath,
        $currentPID,
        $heartbeatPath,
        $monitoredExePaths
    )

    function Write-LiveEvent {
        param([string]$Message)
        Write-Output "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] $Message"
    }

    function Update-Heartbeat {
        param([string]$Path)
        try { [System.IO.File]::WriteAllText($Path, (Get-Date).ToString('o')) } catch {}
    }

    function Get-USBDrives {
        $drives = @()
        try {
            $drives = Get-CimInstance -ClassName Win32_LogicalDisk -Filter "DriveType=2" -ErrorAction Stop |
                Where-Object { $_.DeviceID } |
                ForEach-Object { $_.DeviceID }
        } catch {}
        $drives
    }

    function Test-DriveHasExe {
        param([string]$DriveRoot)
        if (-not $DriveRoot) { return $false }
        $root = if ($DriveRoot.EndsWith('\')) { $DriveRoot } else { "$DriveRoot\" }
        try {
            foreach ($file in [System.IO.Directory]::EnumerateFiles($root, '*.exe', [System.IO.SearchOption]::AllDirectories)) { return $true }
        } catch {
            try {
                $found = Get-ChildItem -Path $root -Filter '*.exe' -File -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1
                if ($found) { return $true }
            } catch {}
        }
        return $false
    }

    function Get-Exclusions {
        $list = @()
        try {
            $prefs = Get-MpPreference -ErrorAction Stop
            if ($prefs.ExclusionPath) { $list += $prefs.ExclusionPath }
            if ($prefs.ExclusionProcess) { $list += $prefs.ExclusionProcess }
            if ($prefs.ExclusionExtension) { $list += $prefs.ExclusionExtension }
        } catch {}
        $list
    }

    function Get-RegistryContentRecursive {
        param([string]$BasePath)
        $results = @{}
        if (-not (Test-Path $BasePath)) { return $results }
        try {
            foreach ($item in (Get-ChildItem -Path $BasePath -Recurse -ErrorAction SilentlyContinue)) {
                if ($item.PSChildName -eq '(default)') { continue }
                $props = Get-ItemProperty -Path $item.PSPath -ErrorAction SilentlyContinue
                if (-not $props) { continue }
                $nonDefault = $props.PSObject.Properties | Where-Object {
                    $_.Name -notlike 'PS*' -and $_.Name -ne '(default)' -and $_.Value -ne $null -and $_.Value -ne ''
                }
                if ($nonDefault.Count -gt 0) {
                    $results[$item.PSPath] = ($nonDefault | ForEach-Object { "$($_.Name)=$($_.Value)" }) -join ', '
                }
            }
        } catch {}
        $results
    }

    function Get-ExistingFolderPath {
        param([string]$BaseDir,[string]$FolderName)
        try {
            $candidate = Join-Path $BaseDir $FolderName
            if (Test-Path $candidate -PathType Container) { return (Get-Item $candidate -ErrorAction SilentlyContinue).FullName }
        } catch {}
        $null
    }

    function Get-FolderContentsSet {
        param([string]$FolderPath)
        $set = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)
        if (-not $FolderPath) { return $set }
        if (-not (Test-Path $FolderPath -PathType Container)) { return $set }
        try {
            foreach ($child in (Get-ChildItem -Path $FolderPath -Force -ErrorAction Stop)) { [void]$set.Add($child.Name) }
        } catch {}
        $set
    }

    function Get-NormalizedPath {
        param([string]$Path)
        if (-not $Path) { return $null }
        try { return [System.IO.Path]::GetFullPath($Path).TrimEnd('\').ToLowerInvariant() }
        catch { return $Path.TrimEnd('\').ToLowerInvariant() }
    }

    function Test-StartsWithAnyPath {
        param([string]$Path,[string[]]$Prefixes)
        if (-not $Path) { return $false }
        foreach ($prefix in $Prefixes) {
            if (-not $prefix) { continue }
            if ($Path -eq $prefix -or $Path.StartsWith($prefix + '\')) { return $true }
        }
        return $false
    }

    function Test-AllowedCommandText {
        param([string]$Text,[string[]]$AllowedMarkers)
        if (-not $Text) { return $false }
        if (-not $AllowedMarkers) { return $false }
        $lowerText = $Text.ToLowerInvariant()
        foreach ($marker in $AllowedMarkers) {
            if ($marker -and $lowerText.Contains($marker.ToLowerInvariant())) { return $true }
        }
        return $false
    }

    function Test-AllowedDnsName {
        param([string]$Name,[string[]]$AllowedHosts)
        if (-not $Name) { return $false }
        if (-not $AllowedHosts) { return $false }
        $cleanName = $Name.TrimEnd('.').ToLowerInvariant()
        foreach ($host in $AllowedHosts) {
            if (-not $host) { continue }
            $cleanHost = $host.TrimEnd('.').ToLowerInvariant()
            if ($cleanName -eq $cleanHost -or $cleanName.EndsWith(".$cleanHost")) { return $true }
        }
        return $false
    }

    function Register-ProcessWatcher {
        param(
            [string]$NormalizedScriptPath,
            [int]$MainPID,
            [int]$WorkerPID,
            [System.Collections.Concurrent.ConcurrentQueue[string]]$Queue,
            [string[]]$MonitoredPaths,
            [string[]]$AllowedCommandMarkers
        )

        Unregister-Event -SourceIdentifier ProcessStartEvent -ErrorAction SilentlyContinue
        $procQuery = 'SELECT * FROM Win32_ProcessStartTrace'

        Register-CimIndicationEvent -Query $procQuery -SourceIdentifier ProcessStartEvent -Action {
            $e = $Event.SourceEventArgs.NewEvent
            $procName = $e.ProcessName
            $pid = $e.ProcessID
            $exePath = $null
            $cmdLine = ''
            $parentName = 'unknown'
            $parentPID = $null
            $normExePath = $null

            try {
                $proc = Get-CimInstance -ClassName Win32_Process -Filter "ProcessId = $pid" -ErrorAction Stop
                $exePath = $proc.ExecutablePath
                $cmdLine = $proc.CommandLine
                $parentPID = $proc.ParentProcessId

                if ($exePath) {
                    try { $normExePath = [System.IO.Path]::GetFullPath($exePath).TrimEnd('\').ToLowerInvariant() }
                    catch { $normExePath = $exePath.TrimEnd('\').ToLowerInvariant() }
                }

                if ($parentPID) {
                    $parent = Get-CimInstance -ClassName Win32_Process -Filter "ProcessId = $parentPID" -ErrorAction SilentlyContinue
                    if ($parent) { $parentName = $parent.Name }
                }
            } catch {}

            $isSelf = $false

            if ($cmdLine -and $NormalizedScriptPath -and $cmdLine.ToLowerInvariant() -like "*$NormalizedScriptPath*") { $isSelf = $true }

            if ($cmdLine -and $AllowedCommandMarkers) {
                $lowerCmd = $cmdLine.ToLowerInvariant()
                foreach ($marker in $AllowedCommandMarkers) {
                    if ($marker -and $lowerCmd.Contains($marker.ToLowerInvariant())) { $isSelf = $true; break }
                }
            }

            if ($pid -eq $MainPID -or $pid -eq $WorkerPID -or $parentPID -eq $MainPID -or $parentPID -eq $WorkerPID) { $isSelf = $true }

            if (-not $isSelf) {
                $isWatchedShell = $procName -match '^(powershell|pwsh|cmd)(\.exe)?$'
                $isFromMonitoredPath = $false

                if ($normExePath) {
                    foreach ($prefix in $MonitoredPaths) {
                        if ($normExePath -eq $prefix -or $normExePath.StartsWith($prefix + '\')) { $isFromMonitoredPath = $true; break }
                    }
                }

                if ($isFromMonitoredPath) {
                    $Queue.Enqueue("Suspicious EXE started: $procName (PID $pid) from $exePath (Parent: $parentName)") | Out-Null
                }
                elseif ($isWatchedShell) {
                    $Queue.Enqueue("Process started: $procName (PID $pid) from $exePath (Parent: $parentName)") | Out-Null
                }
            }
        } | Out-Null
    }

    $prevUSB = Get-USBDrives
