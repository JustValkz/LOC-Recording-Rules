'aim','crack','dll','driver','macro','ahk','internal','external','updater','cleaner','aura','serotonin','melatonin'
)
$KwRe = [regex]::new('(?i)(' + (($Keywords | ForEach-Object { [regex]::Escape($_) }) -join '|') + ')')

function Short([string]$t, [int]$n = 36) {
    if ([string]::IsNullOrEmpty($t)) { return '' }
    if ($t.Length -le $n) { return $t }
    return $t.Substring(0, $n - 3) + '...'
}

function CleanPath([string]$p) {
    if ([string]::IsNullOrEmpty($p)) { return '' }
    if ($p.StartsWith('\??\')) { return $p.Substring(4) }
    return $p
}

function Get-BamRows {
    $hits = New-Object System.Collections.Generic.List[string]
    $recent = New-Object System.Collections.Generic.List[object]
    if (-not (Test-Path -LiteralPath $BamRoot)) { return @() }

    foreach ($sidKey in (Get-ChildItem -LiteralPath $BamRoot -ErrorAction SilentlyContinue)) {
        $sid = $sidKey.PSChildName
        $props = Get-ItemProperty -LiteralPath (Join-Path $BamRoot $sid) -ErrorAction SilentlyContinue
        if (-not $props) { continue }

        foreach ($prop in $props.PSObject.Properties) {
            if ($prop.Name -like 'PS*' -or $prop.Name -eq '(default)') { continue }
            $raw = $prop.Value
            if (-not $raw -or $raw.Length -lt 8) { continue }

            try {
                $tick = [BitConverter]::ToInt64($raw[0..7], 0)
                if ($tick -le 0) { continue }
                $time = [DateTime]::FromFileTimeUtc($tick).ToLocalTime()
                if ($time -lt $Cutoff) { continue }

                $rawName = [string]$prop.Name
                $m = $KwRe.Match($rawName)
                $path = CleanPath $rawName
                $app = Split-Path $path -Leaf
                if ([string]::IsNullOrWhiteSpace($app)) { $app = $rawName }
                $line = $time.ToString('MM/dd HH:mm') + '|' + (Short $app) + '|' + (Short $path 52) + '|' + (Short $sid 28)

                if ($m.Success) {
                    $line += '|' + $m.Groups[1].Value
                    [void]$hits.Add($tick.ToString('D19') + '|' + $line)
                } else {
                    [void]$recent.Add([PSCustomObject]@{ Tick = $tick; Line = $line })
                }
            } catch {}
        }
    }

    $out = New-Object System.Collections.Generic.List[string]
    foreach ($h in ($hits | Sort-Object)) { [void]$out.Add(($h -split '\|', 2)[1]) }

    $slots = [Math]::Max(0, $MaxRows - $out.Count)
    if ($slots -gt 0) {
        foreach ($r in ($recent | Sort-Object Tick -Descending | Select-Object -First $slots)) {
            [void]$out.Add($r.Line)
        }
    }

    return $out.ToArray()
}

