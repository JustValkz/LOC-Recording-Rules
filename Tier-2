function Invoke-EmbeddedToolSection {
    param(
        [int]$StepNumber,
        [int]$TotalSteps,
        [string]$Title,
        [string]$FileName,
        [scriptblock]$ScriptFactory
    )

    Clear-Host
    Write-Host "[ Step $StepNumber of $TotalSteps - $Title ]" -ForegroundColor Cyan
    Show-LoadingBar "Preparing $Title"

    $toolDir = Join-Path $env:TEMP 'RecordingPolicyReviewTools'
    $toolPath = Join-Path $toolDir $FileName

    New-Item -ItemType Directory -Path $toolDir -Force | Out-Null

    $toolText = $null
    try {
        $toolText = & $ScriptFactory
        [System.IO.File]::WriteAllText($toolPath, $toolText, [System.Text.UTF8Encoding]::new($false))
    } catch {
        Write-Host "$Title could not be prepared." -ForegroundColor Red
        Write-Host "Press Enter to continue..." -ForegroundColor Yellow
        Wait-ForEnter
        return
    }

    if (-not $toolText) {
        Write-Host "$Title script was empty." -ForegroundColor Red
        Write-Host "Press Enter to continue..." -ForegroundColor Yellow
        Wait-ForEnter
        return
    }

    Write-Host "Launching $Title..." -ForegroundColor Green
    Write-Host "Close the $Title window when finished." -ForegroundColor Yellow
    Write-Host ""

    try {
        $psExe = Join-Path $env:SystemRoot 'System32\WindowsPowerShell\v1.0\powershell.exe'
        $toolProc = Start-Process -FilePath $psExe -ArgumentList @(
            '-NoProfile',
            '-STA',
            '-WindowStyle', 'Hidden',
            '-ExecutionPolicy', 'Bypass',
            '-File', $toolPath
        ) -WindowStyle Hidden -PassThru -Wait -ErrorAction Stop

        if ($toolProc -and $toolProc.ExitCode -ne 0) {
            Write-Host "$Title closed with exit code $($toolProc.ExitCode)." -ForegroundColor Yellow
        }
    } catch {
        try {
            $toolBlock = [scriptblock]::Create($toolText)
            & $toolBlock
        } catch {
            Write-Host "$Title had an error while opening." -ForegroundColor Red
            Write-Host "Saved copy: $toolPath" -ForegroundColor Yellow
        }
    }

    Write-Host ""
    Write-Host "$Title closed." -ForegroundColor Cyan
    Write-Host "Press Enter to continue..." -ForegroundColor Yellow
    Wait-ForEnter
}

function Invoke-LastActivityViewerSection {
    Clear-Host
    Write-Host "[ Step 5 of 6 - Last Activity Viewer ]" -ForegroundColor Cyan
    Show-LoadingBar "Step 6"

    Write-Host "Note: Scroll through every process since you started your OBS recording." -ForegroundColor Yellow
    Write-Host ""

    $lastActivityDir = Join-Path $env:TEMP 'LastActivity'
    $lastActivityExe = Join-Path $lastActivityDir 'LastActivityView.exe'
    $lastActivityURL = 'https://www.nirsoft.net/utils/lastactivityview.zip'
    $lastActivityZip = Join-Path $env:TEMP 'LastActivityView.zip'

    if (-not (Test-Path $lastActivityExe)) {
        New-Item -ItemType Directory -Path $lastActivityDir -Force | Out-Null
        try { [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 } catch {}

        $downloaded = $false
        for ($try = 1; $try -le 3 -and -not $downloaded; $try++) {
            Write-Host "Downloading Last Activity Viewer ($try/3)..." -ForegroundColor Cyan
            try {
                if (Test-Path $lastActivityZip) { Remove-Item $lastActivityZip -Force -ErrorAction SilentlyContinue }
                Invoke-WebRequest -Uri $lastActivityURL -OutFile $lastActivityZip -UseBasicParsing -ErrorAction Stop
                $downloaded = Test-Path $lastActivityZip
            } catch {
                Start-Sleep -Seconds 1
            }
        }

        if ($downloaded) {
            Show-LoadingBar "Extracting Last Activity Viewer"
            try { Expand-Archive -Path $lastActivityZip -DestinationPath $lastActivityDir -Force -ErrorAction Stop } catch {}
        }
    }

    if (Test-Path $lastActivityExe) {
        Write-Host "Launching Last Activity Viewer..." -ForegroundColor Green
        Write-Host "Scroll at least halfway through the list, then close Last Activity Viewer." -ForegroundColor Yellow
        Write-Host ""

        try {
            $lastProc = Start-MaximizedProcess -FilePath $lastActivityExe
            if ($lastProc) { Wait-Process -Id $lastProc.Id }
        } catch {
            try { $fallbackLast = Start-MaximizedProcess -FilePath $lastActivityExe; if ($fallbackLast) { Wait-Process -Id $fallbackLast.Id } } catch {}
        }

        Write-Host ""
        Write-Host "Last Activity Viewer closed." -ForegroundColor Cyan
    } else {
        Write-Host "ERROR: LastActivityView.exe not found!" -ForegroundColor Red
    }

    Write-Host "Press Enter to continue..." -ForegroundColor Yellow
    Wait-ForEnter
    Clear-Host
}

function Invoke-USBDeviewSection {
    Clear-Host
    Write-Host "[ Step 3 of 7 - USBDeview ]" -ForegroundColor Cyan
    Show-LoadingBar "Step 3"

    Write-Host "=== USB Deview ===" -ForegroundColor Cyan
    Write-Host "NOTE: Scroll all the way down when opened." -ForegroundColor Yellow
    Write-Host ""

    $usbUrl = 'https://www.nirsoft.net/utils/usbdeview.zip'
    $zipPath = Join-Path $env:TEMP 'usbdeview.zip'
    $extractPath = Join-Path $env:TEMP 'usbdeview'

    if (-not (Test-Path $extractPath)) { New-Item -ItemType Directory -Path $extractPath -Force | Out-Null }

    $usbExe = Get-ChildItem -Path $extractPath -Filter 'USBDeview.exe' -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1

    if (-not $usbExe) {
        try { [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 } catch {}

        $downloadedUsb = $false
        for ($try = 1; $try -le 3 -and -not $downloadedUsb; $try++) {
            Write-Host "Downloading USBDeview ($try/3)..." -ForegroundColor Green
            try {
                if (Test-Path $zipPath) { Remove-Item $zipPath -Force -ErrorAction SilentlyContinue }
                Invoke-WebRequest -Uri $usbUrl -OutFile $zipPath -UseBasicParsing -ErrorAction Stop
                $downloadedUsb = Test-Path $zipPath
            } catch {
                Start-Sleep -Seconds 1
            }
        }

        if ($downloadedUsb) {
            Write-Host "Extracting USBDeview..." -ForegroundColor Green
            Show-LoadingBar "Extracting USBDeview"
            try { Expand-Archive -Path $zipPath -DestinationPath $extractPath -Force -ErrorAction Stop } catch {}
            $usbExe = Get-ChildItem -Path $extractPath -Filter 'USBDeview.exe' -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1
        }
    }

    if ($usbExe) {
        Write-Host "Launching USBDeview..." -ForegroundColor Green
        Write-Host "Scroll all the way down, then close USBDeview." -ForegroundColor Yellow
        Write-Host ""

        try {
            $usbProc = Start-MaximizedProcess -FilePath $usbExe.FullName
            if ($usbProc) { Wait-Process -Id $usbProc.Id }
        } catch {
            try { $fallbackUsb = Start-MaximizedProcess -FilePath $usbExe.FullName; if ($fallbackUsb) { Wait-Process -Id $fallbackUsb.Id } } catch {}
        }

        Write-Host ""
        Write-Host "USBDeview closed." -ForegroundColor Cyan
    } else {
        Write-Host "ERROR: USBDeview.exe not found!" -ForegroundColor Red
    }

    Write-Host "Press Enter to continue..." -ForegroundColor Cyan
    Wait-ForEnter
    Clear-Host
}

