        foreach ($e in $exclRemoved) { Write-LiveEvent "Exclusion removed: $e" }
        $prevExcl = $curExcl

        try {
            $curRTP = (Get-MpComputerStatus).RealTimeProtectionEnabled
            if ($prevRTP -ne $null -and $curRTP -ne $prevRTP) {
                Write-LiveEvent "Real-time protection changed to $(if ($curRTP) { 'enabled' } else { 'disabled' })"
            }
            $prevRTP = $curRTP
        } catch {}

        foreach ($base in $registryBasePaths) {
            $curReg = Get-RegistryContentRecursive $base
            $prevRegMap = $prevReg[$base]

            foreach ($k in $curReg.Keys) {
                if (-not $prevRegMap.ContainsKey($k)) { Write-LiveEvent "Registry key created under $base : $k - Values: $($curReg[$k])" }
                elseif ($curReg[$k] -ne $prevRegMap[$k]) { Write-LiveEvent "Registry key changed under $base : $k - New values: $($curReg[$k])" }
            }

            foreach ($k in $prevRegMap.Keys) {
                if (-not $curReg.ContainsKey($k)) { Write-LiveEvent "Registry key deleted under $base : $k" }
            }

            $prevReg[$base] = $curReg
        }

        foreach ($t in $folderTargets) {
            $targetKey = "$($t.Base)|$($t.Name)"
            $prevFolder = $prevFolders[$targetKey]
            $curPath = Get-ExistingFolderPath -BaseDir $t.Base -FolderName $t.Name
            $curExists = ($curPath -ne $null)
            $curContents = Get-FolderContentsSet -FolderPath $curPath

            if ($curExists -ne $prevFolder.Exists) {
                if ($curExists) { Write-LiveEvent "Folder CREATED: $curPath (match for '$($t.Name)')" }
                else { Write-LiveEvent "Folder DELETED: $($prevFolder.ActualPath)" }
            }

            if ($curExists) {
                foreach ($item in $curContents) {
                    if (-not $prevFolder.Contents.Contains($item)) { Write-LiveEvent "New item created: $(Join-Path $curPath $item)" }
                }
            }

            $prevFolders[$targetKey] = @{
                Base = $t.Base
                Name = $t.Name
                Exists = $curExists
                ActualPath = $curPath
                Contents = $curContents
            }
        }

        if (Test-Path $psHistoryPath) {
            try {
                $histInfo = Get-Item $psHistoryPath -ErrorAction Stop
                $sz = $histInfo.Length
                $tm = $histInfo.LastWriteTime

                if ($sz -ne $prevHistSize -or $tm -ne $prevHistTime) {
                    $newHist = Get-Content $psHistoryPath -ErrorAction Stop
                    $newCount = $newHist.Count
                    $oldCount = $prevHist.Count

                    if ($newCount -gt $oldCount) {
                        $addedCount = $newCount - $oldCount
                        $selfMatch = $false

                        if ($oldCount -lt $newCount) {
                            $newLines = $newHist[$oldCount..($newCount - 1)]
                            foreach ($line in $newLines) {
                                if ($normalizedScriptPath -and $line.ToLowerInvariant() -like "*$normalizedScriptPath*") { $selfMatch = $true; break }
                                if (Test-AllowedCommandText -Text $line -AllowedMarkers $allowedCommandMarkers) { $selfMatch = $true; break }
                            }
                        }

                        if (-not $selfMatch) {
                            if ($addedCount -eq 1) {
                                $cmd = $newHist[-1]
                                if ($cmd -and $cmd.Trim()) {
                                    if ($cmd.Length -gt 200) { $cmd = $cmd.Substring(0, 200) + '...' }
                                    Write-LiveEvent "PowerShell command executed: $cmd"
                                }
                            } else {
                                Write-LiveEvent "PowerShell script executed ($addedCount lines)"
                            }
                        }
                    }
                    elseif ($newCount -lt $oldCount) {
                        $hours = ((Get-Date) - $tm).TotalHours
                        if ($hours -le 24 -and $newCount -eq 0) { Write-LiveEvent 'PowerShell history file was CLEARED (empty, last modified within 24 hours)' }
                        elseif ($hours -le 24) { Write-LiveEvent "PowerShell history file was TRUNCATED (lost $($oldCount - $newCount) lines, last modified within 24 hours)" }
                        else { Write-LiveEvent 'PowerShell history file changed (size reduced)' }
                    }

                    $prevHist = $newHist
                    $prevHistSize = $sz
                    $prevHistTime = $tm
                }
            } catch {}
        }

        try {
            $events = Get-WinEvent -LogName $defenderLog -MaxEvents 50 -ErrorAction SilentlyContinue |
                Where-Object { $_.Id -in $eventIDs -and $_.TimeCreated -gt $lastEventTime }

            foreach ($evt in $events) {
                $lastEventTime = $evt.TimeCreated
                if ($evt.Message -match 'security intelligence version updated|engine version updated|platform version updated|signature version updated') { continue }
                Write-LiveEvent "Defender severe threat event: $($evt.Message)"
            }
        } catch {}

        try {
            $dnsCache = Get-DnsClientCache -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Name -Unique
            foreach ($entry in $dnsCache) {
                if (Test-AllowedDnsName -Name $entry -AllowedHosts $allowedDnsHosts) { continue }
                foreach ($target in $dnsTargets) {
                    foreach ($pattern in $target.Patterns) {
                        if ($entry -match $pattern) {
                            if (-not $alertedDnsLabels.Contains($target.Label)) {
                                [void]$alertedDnsLabels.Add($target.Label)
                                Write-LiveEvent "DNS match found: $($target.Label)"
                            }
                            break
                        }
                    }
                }
            }
        } catch {}

        try {
            $currentRunningPathProcesses = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)
            $procList = Get-CimInstance Win32_Process -ErrorAction Stop
            foreach ($proc in $procList) {
                if ($proc.ProcessId -eq $currentPID -or $proc.ProcessId -eq $PID) { continue }
                $exePath = $proc.ExecutablePath
                if (-not $exePath) { continue }
                $norm = Get-NormalizedPath $exePath
                if (Test-StartsWithAnyPath -Path $norm -Prefixes $monitoredExePaths) {
                    $key = "$($proc.ProcessId)|$norm"
                    [void]$currentRunningPathProcesses.Add($key)
                    if (-not $prevRunningPathProcesses.Contains($key)) {
                        Write-LiveEvent "Running EXE detected in monitored path: $($proc.Name) (PID $($proc.ProcessId)) from $exePath"
                    }
                }
            }
            $prevRunningPathProcesses = $currentRunningPathProcesses
        } catch {}

        $procMsg = $null
        while ($procQueue.TryDequeue([ref]$procMsg)) { Write-LiveEvent $procMsg }

        Start-Sleep -Milliseconds 250
    }
} -ArgumentList $folderTargets, $registryBasePaths, $psHistoryPath, $scriptPath, $currentPID, $monitorHeartbeatPath, $monitoredExePaths

