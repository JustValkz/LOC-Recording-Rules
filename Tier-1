                        }
                        else {
                            if ($oldCount -lt $newCount) {
                                $newLines = $newHist[$oldCount..($newCount - 1)]
                                foreach ($line in $newLines) {
                                    if ($normalizedScriptPath -and $line.ToLowerInvariant() -like "*$normalizedScriptPath*") {
                                        $selfMatch = $true
                                        break
                                    }

                                    if (Test-AllowedCommandText -Text $line -AllowedMarkers $allowedCommandMarkers) {
                                        $selfMatch = $true
                                        break
                                    }
                                }
                            }

                            if (-not $selfMatch) {
                                Write-LiveEvent "PowerShell script executed ($addedCount lines)"
                            }
                        }
                    }
                    elseif ($newCount -lt $oldCount) {
                        $hours = ((Get-Date) - $tm).TotalHours

                        if ($hours -le 24 -and $newCount -eq 0) {
                            Write-LiveEvent 'PowerShell history file was CLEARED (empty, last modified within 24 hours)'
                        }
                        elseif ($hours -le 24) {
                            Write-LiveEvent "PowerShell history file was TRUNCATED (lost $($oldCount - $newCount) lines, last modified within 24 hours)"
                        }
                        else {
                            Write-LiveEvent 'PowerShell history file changed (size reduced)'
                        }
                    }

                    $prevHist = $newHist
                    $prevHistSize = $sz
                    $prevHistTime = $tm
                }
            } catch {}
        }

        try {
            $events = Get-WinEvent -LogName $defenderLog -MaxEvents 50 -ErrorAction SilentlyContinue |
                Where-Object { $_.Id -in $eventIDs -and $_.TimeCreated -gt $lastEventTime }

            foreach ($evt in $events) {
                $lastEventTime = $evt.TimeCreated

                if ($evt.Message -match 'security intelligence version updated|engine version updated|platform version updated|signature version updated') {
                    continue
                }

                $msg = switch ($evt.Id) {
                    1116 { "Defender threat detected: $($evt.Message)" }
                    1117 { "Defender action taken: $($evt.Message)" }
                    1118 { "Defender action failed: $($evt.Message)" }
                    1119 { "Defender severe threat event: $($evt.Message)" }
                    default { "Defender event $($evt.Id): $($evt.Message)" }
                }

                Write-LiveEvent $msg
            }
        } catch {}

        try {
            $dnsCache = Get-DnsClientCache -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Name -Unique

            foreach ($entry in $dnsCache) {
                if (Test-AllowedDnsName -Name $entry -AllowedHosts $allowedDnsHosts) {
