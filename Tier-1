        'https://raw.githubusercontent.com/reggiecarterthesecond-web/recording-policies/refs/heads/main/rejoin/tier-1',
        'https://raw.githubusercontent.com/reggiecarterthesecond-web/recording-policies/refs/heads/main/tier-2',
        'https://raw.githubusercontent.com/reggiecarterthesecond-web/recording-policies/refs/heads/main/rejoin/tier-2'
    )

