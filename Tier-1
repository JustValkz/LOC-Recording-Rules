                                Write-LiveEvent "DNS match found: $($target.Label)"
                            }
                            break
                        }
                    }
                }
            }
        } catch {}

        try {
            $currentRunningPathProcesses = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)
            $procList = Get-CimInstance Win32_Process -ErrorAction Stop

            foreach ($proc in $procList) {
                if ($proc.ProcessId -eq $currentPID -or $proc.ProcessId -eq $PID) { continue }

                $exePath = $proc.ExecutablePath
                if (-not $exePath) { continue }

                $norm = Get-NormalizedPath $exePath
                if (Test-StartsWithAnyPath -Path $norm -Prefixes $monitoredExePaths) {
                    $key = "$($proc.ProcessId)|$norm"
                    [void]$currentRunningPathProcesses.Add($key)

                    if (-not $prevRunningPathProcesses.Contains($key)) {
                        Write-LiveEvent "Running EXE detected in monitored path: $($proc.Name) (PID $($proc.ProcessId)) from $exePath"
                    }
                }
            }

            $prevRunningPathProcesses = $currentRunningPathProcesses
        } catch {}

        $procMsg = $null
        while ($procQueue.TryDequeue([ref]$procMsg)) {
            Write-LiveEvent $procMsg
        }

        Start-Sleep -Milliseconds 200
    }
} -ArgumentList $folderTargets, $registryBasePaths, $psHistoryPath, $scriptPath, $currentPID, $monitorHeartbeatPath, $monitoredExePaths

