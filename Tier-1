    $prevHist = @()
    $prevHistSize = 0
    $prevHistTime = $null

    if (Test-Path $psHistoryPath) {
        try {
            $histInfo = Get-Item $psHistoryPath -ErrorAction Stop
            $prevHist = Get-Content $psHistoryPath -ErrorAction Stop
            $prevHistSize = $histInfo.Length
            $prevHistTime = $histInfo.LastWriteTime
        } catch {}
    }

    $prevRunningPathProcesses = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)
    try {
        $runningNow = Get-CimInstance Win32_Process -ErrorAction Stop
        foreach ($proc in $runningNow) {
            if ($proc.ProcessId -eq $currentPID -or $proc.ProcessId -eq $PID) { continue }

            $exePath = $proc.ExecutablePath
            if (-not $exePath) { continue }

            $norm = Get-NormalizedPath $exePath
            if (Test-StartsWithAnyPath -Path $norm -Prefixes $monitoredExePaths) {
                [void]$prevRunningPathProcesses.Add("$($proc.ProcessId)|$norm")
            }
        }
    } catch {}

    $lastEventTime = (Get-Date).AddHours(-1)
    $defenderLog = 'Microsoft-Windows-Windows Defender/Operational'
    $eventIDs = @(1116, 1117, 1118, 1119)

