        $targetKey = "$($t.Base)|$($t.Name)"
        $path = Get-ExistingFolderPath -BaseDir $t.Base -FolderName $t.Name
        $prevFolders[$targetKey] = @{
            Base = $t.Base
            Name = $t.Name
            Exists = ($path -ne $null)
            ActualPath = $path
