function Write-LocRecScriptCacheContent {
    param(
        [string]$CachePath,
        [string]$Content
    )

    if (-not $CachePath -or -not $Content) { return $false }

    try {
        $utf8NoBom = New-Object System.Text.UTF8Encoding $false
        [System.IO.File]::WriteAllText($CachePath, $Content, $utf8NoBom)
        return (Test-Path -LiteralPath $CachePath -PathType Leaf)
    } catch {
        return $false
    }
}

function Initialize-LocRecScriptCache {
    param([switch]$ForceRefresh)

    $cachePath = Get-LocRecScriptCachePath

    if (-not $ForceRefresh -and (Test-Path -LiteralPath $cachePath -PathType Leaf)) {
        $cachedInfo = Get-Item -LiteralPath $cachePath -ErrorAction SilentlyContinue
        if ($cachedInfo -and $cachedInfo.Length -gt 1000) {
            return $cachePath
        }
    }

    try { [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12 } catch {}

    $sourceCandidates = @(
        $PSCommandPath,
        $MyInvocation.MyCommand.Path,
        $MyInvocation.PSCommandPath
    )

    foreach ($candidate in $sourceCandidates) {
        if (-not $candidate) { continue }
        if (-not (Test-Path -LiteralPath $candidate -PathType Leaf)) { continue }

        try {
            $content = Get-Content -LiteralPath $candidate -Raw -ErrorAction Stop
            if (Write-LocRecScriptCacheContent -CachePath $cachePath -Content $content) {
                return $cachePath
            }
        } catch {}
    }

    $downloadUrls = @($script:LocRecSourceUrl)

    try {
        $recentCommands = Get-History -Count 20 -ErrorAction SilentlyContinue | Where-Object { $_.CommandLine }
        foreach ($entry in ($recentCommands | Select-Object -Last 5)) {
            if ($entry.CommandLine -match '(?i)https?://[^\s''"]+') {
                $downloadUrls += $matches[0]
            }
        }
    } catch {}

    $downloadUrls = $downloadUrls | Where-Object { $_ } | Select-Object -Unique

    foreach ($downloadUrl in $downloadUrls) {
        try {
            $content = (Invoke-WebRequest -Uri $downloadUrl -UseBasicParsing -ErrorAction Stop).Content
            if ($content -and $content.Length -gt 1000 -and (Write-LocRecScriptCacheContent -CachePath $cachePath -Content $content)) {
                return $cachePath
            }
        } catch {}
    }

    if (Test-Path -LiteralPath $cachePath -PathType Leaf) {
        return $cachePath
    }

    $null
}

