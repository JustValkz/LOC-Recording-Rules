            '(^|\.)ghostbin\.[a-z]+$',
            '(^|\.)hastebin\.[a-z]+$',
            '(^|\.)paste\.ee$',
            '(^|\.)paste\.gg$',
            '(^|\.)justpaste\.it$',
            '(^|\.)dpaste\.[a-z]+$',
            '(^|\.)controlc\.com$',
            '(^|\.)pastecode\.[a-z]+$',
            '(^|\.)rentry\.co$',
            '(^|\.)textbin\.[a-z]+$',
            '(^|\.)0bin\.[a-z]+$',
