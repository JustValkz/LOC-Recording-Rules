function Show-LoadingBar {
    param([string]$StepName)

    for ($i = 0; $i -le 20; $i++) {
        $percent = $i * 5
        $bar = ("#" * $i) + ("-" * (20 - $i))
        Write-Host "`r[ $bar ] $percent%" -NoNewline
        Start-Sleep -Milliseconds 120
    }

    Write-Host "`n"
}

function Wait-ForEnter {
    Start-Sleep -Milliseconds 250

    try {
        while ([Console]::KeyAvailable) {
            [Console]::ReadKey($true) | Out-Null
            Start-Sleep -Milliseconds 25
        }
    } catch {}

    [Console]::ReadLine() | Out-Null
}

function Confirm-EndMonitoring {
    while ($true) {
        Write-Host "Do you really want to end? (y/n)" -ForegroundColor Yellow
        $answer = Read-Host

        if ($answer.Trim().ToLower() -match '^y') {
            return $true
        }

        if ($answer.Trim().ToLower() -match '^n') {
            return $false
        }
    }
}

function Confirm-ExitWithDelay {
    while ($true) {
        Write-Host ""
        Write-Host "Do you want to exit?" -ForegroundColor Yellow
        Write-Host "Press Enter after the countdown to exit, or type N then press Enter to stay on this screen." -ForegroundColor Yellow

        try {
            while ([Console]::KeyAvailable) {
                [Console]::ReadKey($true) | Out-Null
                Start-Sleep -Milliseconds 25
            }
        } catch {}

        for ($i = 3; $i -ge 1; $i--) {
            Write-Host "`rExit unlocks in $i second(s)..." -ForegroundColor Cyan -NoNewline
            Start-Sleep -Seconds 1
        }

        Write-Host "`rYou can press Enter now to exit, or type N then press Enter to stay.          " -ForegroundColor Yellow

        try {
            while ([Console]::KeyAvailable) {
                [Console]::ReadKey($true) | Out-Null
                Start-Sleep -Milliseconds 25
            }
        } catch {}

        $answer = [Console]::ReadLine()

        if ([string]::IsNullOrWhiteSpace($answer)) {
            return $true
        }

        if ($answer.Trim() -match '^(n|no)$') {
            Write-Host "Exit cancelled. Results will stay open." -ForegroundColor Green
            continue
        }

        if ($answer.Trim() -match '^(y|yes)$') {
            return $true
        }

        Write-Host "Invalid choice. Press Enter to exit, or type N to stay." -ForegroundColor Yellow
    }
}

function Write-Section {
    param($Title, $Lines)

    Write-Host "--- $Title ---" -ForegroundColor Cyan

    foreach ($line in $Lines) {
        if ($line -like "SUCCESS*") {
            Write-Host $line -ForegroundColor Green
        }
        elseif ($line -like "FAILURE*") {
            Write-Host $line -ForegroundColor Red
        }
        elseif ($line -like "WARNING*") {
            Write-Host $line -ForegroundColor Yellow
        }
        elseif ($line -like "INFO*") {
            Write-Host $line -ForegroundColor Yellow
        }
        else {
            Write-Host $line -ForegroundColor White
        }
    }

    Write-Host ""
}

function Add-Event {
    param(
        [System.Collections.Generic.List[string]]$List,
        [string]$Message
    )

    $List.Add("[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] $Message")
}

function Get-USBDrives {
    $drives = @()

    try {
        $drives = Get-CimInstance -ClassName Win32_LogicalDisk -Filter "DriveType=2" -ErrorAction Stop |
            Where-Object { $_.DeviceID } |
            ForEach-Object { $_.DeviceID }
    } catch {}

    $drives
}

function Test-DriveHasExe {
    param([string]$DriveRoot)

    if (-not $DriveRoot) { return $false }

    $root = if ($DriveRoot.EndsWith("\")) { $DriveRoot } else { "$DriveRoot\" }

    try {
        foreach ($file in [System.IO.Directory]::EnumerateFiles($root, "*.exe", [System.IO.SearchOption]::AllDirectories)) {
            return $true
        }
    } catch {
        try {
            $found = Get-ChildItem -Path $root -Filter "*.exe" -File -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1
            if ($found) { return $true }
        } catch {}
    }

    return $false
}

function Get-Exclusions {
    $list = @()

    try {
        $prefs = Get-MpPreference -ErrorAction Stop
        if ($prefs.ExclusionPath) { $list += $prefs.ExclusionPath }
        if ($prefs.ExclusionProcess) { $list += $prefs.ExclusionProcess }
        if ($prefs.ExclusionExtension) { $list += $prefs.ExclusionExtension }
    } catch {}

    $list
}

function Get-RegistryContentRecursive {
    param([string]$BasePath)

    $results = @{}
    if (-not (Test-Path $BasePath)) { return $results }

    try {
        foreach ($item in (Get-ChildItem -Path $BasePath -Recurse -ErrorAction SilentlyContinue)) {
            if ($item.PSChildName -eq '(default)') { continue }

            $props = Get-ItemProperty -Path $item.PSPath -ErrorAction SilentlyContinue
            if (-not $props) { continue }

            $nonDefault = $props.PSObject.Properties | Where-Object {
                $_.Name -notlike 'PS*' -and $_.Name -ne '(default)' -and $_.Value -ne $null -and $_.Value -ne ''
            }

            if ($nonDefault.Count -gt 0) {
                $results[$item.PSPath] = ($nonDefault | ForEach-Object { "$($_.Name)=$($_.Value)" }) -join ', '
            }
        }
    } catch {}

    $results
}

function Get-ExistingFolderPath {
    param(
        [string]$BaseDir,
        [string]$FolderName
    )

    try {
        $candidate = Join-Path $BaseDir $FolderName
        if (Test-Path $candidate -PathType Container) {
            return (Get-Item $candidate -ErrorAction SilentlyContinue).FullName
        }
    } catch {}

    $null
}

function Get-FolderContentsSet {
    param([string]$FolderPath)

    $set = [System.Collections.Generic.HashSet[string]]::new([System.StringComparer]::OrdinalIgnoreCase)

    if (-not $FolderPath) { return $set }
    if (-not (Test-Path $FolderPath -PathType Container)) { return $set }

    try {
        foreach ($child in (Get-ChildItem -Path $FolderPath -Force -ErrorAction Stop)) {
            [void]$set.Add($child.Name)
        }
    } catch {}

    $set
}

function Get-NormalizedPath {
    param([string]$Path)

    if (-not $Path) { return $null }

    try {
        return [System.IO.Path]::GetFullPath($Path).TrimEnd('\').ToLowerInvariant()
    } catch {
        return $Path.TrimEnd('\').ToLowerInvariant()
    }
}

function Test-StartsWithAnyPath {
