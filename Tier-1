        foreach ($e in $exclRemoved) { Write-LiveEvent "Exclusion removed: $e" }

        $prevExcl = $curExcl

        try {
            $curRTP = (Get-MpComputerStatus).RealTimeProtectionEnabled
            if ($prevRTP -ne $null -and $curRTP -ne $prevRTP) {
                Write-LiveEvent "Real-time protection changed to $(if ($curRTP) { 'enabled' } else { 'disabled' })"
            }
            $prevRTP = $curRTP
        } catch {}

        foreach ($base in $registryBasePaths) {
            $curReg = Get-RegistryContentRecursive $base
